SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=your-app-name.azurewebsites.net,localhost,127.0.0.1

# Set false to use PostgreSQL (recommended for Azure deployment)
USE_SQLITE=False

# PostgreSQL running on your VM
DB_NAME=refinery_monitor_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=your-vm-public-ip-or-dns
DB_PORT=5432
# For VM PostgreSQL usually use 'prefer' (or disable SSL with empty value)
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=60

GEMINI_API_KEY=replace-with-your-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=10
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1.2

# Optional: auto-import CSV during deployment startup
SEED_FROM_CSV=true
