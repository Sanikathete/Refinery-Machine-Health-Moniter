# Core
SECRET_KEY=replace-with-long-random-secret
DEBUG=False
TIME_ZONE=UTC

# Hosts / Proxy
ALLOWED_HOSTS=neurorefine.duckdns.org,<your-azure-app>.azurewebsites.net
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://neurorefine.duckdns.org,https://<your-azure-app>.azurewebsites.net

# CORS
AZURE_FRONTEND_URL=https://neurorefine.duckdns.org
CORS_ALLOWED_ORIGINS=https://neurorefine.duckdns.org
CORS_ALLOW_ALL_ORIGINS=False

# Database 
USE_SQLITE=False
DB_NAME=refinery_monitor_db
DB_USER=<db-user>
DB_PASSWORD=<db-password>
DB_HOST=<db-host>
DB_PORT=5432
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=10
DB_CONN_MAX_AGE=120
DB_CONN_HEALTH_CHECKS=True

# Gemini
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=10
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1.2

# Security headers
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
